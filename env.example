# Home Assistant Configuration
# Copy this file to .env and update with your values

# Home Assistant URL (when using bridge networking)
HA_URL=http://home-assistant:8123

# Home Assistant URL (when using host networking)
# HA_URL=http://localhost:8123

# Home Assistant long-lived access token
# Get this from: Home Assistant → Profile → Long-lived access tokens
HA_AUTH_TOKEN=your_long_lived_access_token_here

# MQTT broker used by Home Assistant for runtime entity discovery
# HA_MQTT_BROKER_URL=tcp://localhost:1883
# HA_MQTT_USERNAME=your_mqtt_username
# HA_MQTT_PASSWORD=your_mqtt_password

# Dry-run mode (for testing without actual device control)
# Set to "true" to enable dry-run mode (all service calls will be logged but not executed)
# DRY_RUN=true

# Debug mode (for verbose logging)
# Set to "true" to enable debug logging (shows detailed optimization steps and internal calculations)
# DEBUG=true
